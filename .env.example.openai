# =========================
# LvsheProject 环境变量模板 — 通用 OpenAI 兼容接口
# 复制本文件为 .env 后填写真实配置
#
# 适用于任何提供 OpenAI 兼容 API 的供应商：
#   - OpenAI 官方 (https://api.openai.com/v1)
#   - DeepSeek (https://api.deepseek.com/v1)
#   - Moonshot/Kimi (https://api.moonshot.cn/v1)
#   - 零一万物 (https://api.lingyiwanwu.com/v1)
#   - 其他兼容 OpenAI API 格式的供应商
# =========================

APP_NAME=LvsheProject
APP_ENV=dev
APP_DEBUG=true

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ===== LLM 供应商选择 =====
LLM_PROVIDER=openai

# ===== 通用 OpenAI 兼容接口配置 =====
# 将以下配置修改为你使用的供应商对应的值
#
# OpenAI 官方示例：
#   OPENAI_COMPAT_API_KEY=sk-xxx
#   OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
#
# DeepSeek 示例：
#   OPENAI_COMPAT_API_KEY=sk-xxx
#   OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
#
# Moonshot/Kimi 示例：
#   OPENAI_COMPAT_API_KEY=sk-xxx
#   OPENAI_COMPAT_BASE_URL=https://api.moonshot.cn/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1

# 文本模型（根据供应商修改）
# OpenAI: gpt-4o / gpt-4o-mini / gpt-4-turbo
# DeepSeek: deepseek-chat / deepseek-coder
# Moonshot: moonshot-v1-8k / moonshot-v1-32k
OPENAI_COMPAT_DEFAULT_MODEL=gpt-4o
OPENAI_COMPAT_CHAT_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo

# 视觉模型（需要支持图片输入的模型）
OPENAI_COMPAT_VISION_MODEL=gpt-4o

# 图像生成模型
OPENAI_COMPAT_IMAGE_MODEL=dall-e-3

# ===== 角色专用模型覆盖（可选） =====
# 为法庭模拟中的不同角色指定不同模型
# MODEL_SPEECH=gpt-4o-mini    # 陈述/回答（轻量快速）
# MODEL_DECISION=gpt-4o       # 法官追问决策（稳定 JSON）
# MODEL_VERDICT=gpt-4o        # 最终判决（强推理）

# ChromaDB
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=lvshe_law_docs

# 上传文件目录
UPLOAD_DIR=data/uploads

# mem0 本地模式
MEMORY_ENABLED=true
MEMORY_STORE_PATH=data/memory

# Playwright
BROWSER_HEADLESS=true

# 图像 RAG 配置
IMAGE_RAG_ENABLED=true
IMAGE_CHROMA_COLLECTION_NAME=lvshe_law_images
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# Graph RAG / Neo4j 配置
GRAPH_RAG_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# MinIO 对象存储配置
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lvshe-documents
MINIO_SECURE=false

# Unstructured.io 文档解析配置
UNSTRUCTURED_ENABLED=true
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=

# 合同审查输出配置
CONTRACT_OUTPUT_DIR=output/contract_review
