# =========================
# LvsheProject 环境变量模板 — 智谱AI (ZhipuAI / BigModel)
# 复制本文件为 .env 后填写真实配置
# 供应商文档：https://open.bigmodel.cn/
# =========================

APP_NAME=LvsheProject
APP_ENV=dev
APP_DEBUG=true

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ===== LLM 供应商选择 =====
LLM_PROVIDER=zhipu

# ===== 智谱 AI 配置 =====
# 获取地址：https://open.bigmodel.cn/ → API Keys
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 文本模型（4 个可选）
# glm-4.7-flash  — 轻量高速，支持 reasoning_content 思考过程
# glm-4.7-flashx — 轻量高速增强版
# glm-4.6        — 通用文本模型
# glm-5.2        — 旗舰模型，长程任务与代码
DEFAULT_LLM_MODEL=glm-4.7-flash
ZHIPU_CHAT_MODELS=glm-4.7-flash,glm-4.7-flashx,glm-4.6,glm-5.2

# 视觉模型（图片/扫描件文字识别）
ZHIPU_VISION_MODEL=glm-ocr

# 图像生成模型（文档批注与图片生成）
ZHIPU_IMAGE_MODEL=glm-image

# ===== 角色专用模型覆盖（可选） =====
# 为法庭模拟中的不同角色指定不同模型
# MODEL_SPEECH=glm-4.7-flash     # 陈述/回答（需要思考过程展示）
# MODEL_DECISION=glm-4.6         # 法官追问决策（需要稳定 JSON 输出）
# MODEL_VERDICT=glm-5.2          # 最终判决（需要强推理能力）

# ChromaDB
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=lvshe_law_docs

# 上传文件目录
UPLOAD_DIR=data/uploads

# mem0 本地模式
MEMORY_ENABLED=true
MEMORY_STORE_PATH=data/memory

# Playwright
BROWSER_HEADLESS=true

# 图像 RAG 配置
IMAGE_RAG_ENABLED=true
IMAGE_CHROMA_COLLECTION_NAME=lvshe_law_images
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# Graph RAG / Neo4j 配置
GRAPH_RAG_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# MinIO 对象存储配置
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lvshe-documents
MINIO_SECURE=false

# Unstructured.io 文档解析配置
UNSTRUCTURED_ENABLED=true
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=

# 合同审查输出配置
CONTRACT_OUTPUT_DIR=output/contract_review
