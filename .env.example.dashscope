# =========================
# LvsheProject 环境变量模板 — 百炼 / 通义千问 (DashScope)
# 复制本文件为 .env 后填写真实配置
# 供应商文档：https://help.aliyun.com/zh/dashscope/
# =========================

APP_NAME=LvsheProject
APP_ENV=dev
APP_DEBUG=true

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ===== LLM 供应商选择 =====
LLM_PROVIDER=dashscope

# ===== 百炼 / 通义千问 (DashScope) 配置 =====
# 获取地址：https://bailian.console.aliyun.com/ → API Key 管理
# 使用 OpenAI 兼容接口接入，无需额外 SDK
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 文本模型（3 个可选）
# qwen-turbo — 轻量高速，适合日常对话
# qwen-plus  — 均衡性能与速度（推荐默认）
# qwen-max   — 旗舰模型，最强推理能力
DASHSCOPE_DEFAULT_MODEL=qwen-plus
DASHSCOPE_CHAT_MODELS=qwen-turbo,qwen-plus,qwen-max

# 视觉模型（图片/文档识别）
DASHSCOPE_VISION_MODEL=qwen-vl-max

# 图像生成模型
DASHSCOPE_IMAGE_MODEL=wanx2.1-aimage

# ===== 角色专用模型覆盖（可选） =====
# 为法庭模拟中的不同角色指定不同模型
# MODEL_SPEECH=qwen-turbo    # 陈述/回答（轻量快速）
# MODEL_DECISION=qwen-plus   # 法官追问决策（稳定 JSON）
# MODEL_VERDICT=qwen-max     # 最终判决（强推理）

# ChromaDB
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=lvshe_law_docs

# 上传文件目录
UPLOAD_DIR=data/uploads

# mem0 本地模式
MEMORY_ENABLED=true
MEMORY_STORE_PATH=data/memory

# Playwright
BROWSER_HEADLESS=true

# 图像 RAG 配置
IMAGE_RAG_ENABLED=true
IMAGE_CHROMA_COLLECTION_NAME=lvshe_law_images
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# Graph RAG / Neo4j 配置
GRAPH_RAG_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# MinIO 对象存储配置
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lvshe-documents
MINIO_SECURE=false

# Unstructured.io 文档解析配置
UNSTRUCTURED_ENABLED=true
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=

# 合同审查输出配置
CONTRACT_OUTPUT_DIR=output/contract_review
