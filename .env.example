# =========================
# LvsheProject 环境变量模板（默认：智谱AI）
# 复制本文件为 .env 后填写真实配置
#
# 切换 LLM 供应商只需修改 LLM_PROVIDER 和对应 API Key
# 各供应商详细配置请参考：
#   .env.example.zhipu    — 智谱AI（GLM 系列）
#   .env.example.dashscope — 百炼/通义千问（Qwen 系列）
#   .env.example.openai    — 通用 OpenAI 兼容接口
# =========================

APP_NAME=LvsheProject
APP_ENV=dev
APP_DEBUG=true

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ===== LLM 供应商选择 =====
# 可选值：zhipu / dashscope / openai
LLM_PROVIDER=zhipu

# ===== 智谱 AI (ZhipuAI / BigModel) 配置 =====
# 获取地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 默认语言模型（4 个文本模型可选）
# 可选值：glm-4.7-flash / glm-4.7-flashx / glm-4.6 / glm-5.2
DEFAULT_LLM_MODEL=glm-4.7-flash

# 语言模型清单（逗号分隔，用于前端模型选择）
ZHIPU_CHAT_MODELS=glm-4.7-flash,glm-4.7-flashx,glm-4.6,glm-5.2

# 文档分析视觉模型（GLM-OCR，用于图片/扫描件文字识别）
ZHIPU_VISION_MODEL=glm-ocr

# 文档批注与图片生成模型（GLM-Image）
ZHIPU_IMAGE_MODEL=glm-image

# ===== 百炼 / 通义千问 (DashScope) 配置 =====
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_DEFAULT_MODEL=qwen-plus
DASHSCOPE_CHAT_MODELS=qwen-turbo,qwen-plus,qwen-max
DASHSCOPE_VISION_MODEL=qwen-vl-max
DASHSCOPE_IMAGE_MODEL=wanx2.1-aimage

# ===== 通用 OpenAI 兼容接口配置 =====
# 适用于任何提供 OpenAI 兼容 API 的供应商（如 OpenAI / DeepSeek / Moonshot 等）
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_DEFAULT_MODEL=gpt-4o
OPENAI_COMPAT_CHAT_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo
OPENAI_COMPAT_VISION_MODEL=gpt-4o
OPENAI_COMPAT_IMAGE_MODEL=dall-e-3

# ===== 角色专用模型覆盖（供应商无关，留空则使用默认模型） =====
# 用于多智能体法庭模拟中的角色分工
# MODEL_SPEECH=        # 陈述/回答模型（留空=使用默认模型）
# MODEL_DECISION=      # 法官决策模型（留空=使用默认模型）
# MODEL_VERDICT=       # 最终判决模型（留空=使用默认模型）

# ChromaDB
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=lvshe_law_docs

# 上传文件目录
UPLOAD_DIR=data/uploads

# mem0 本地模式
MEMORY_ENABLED=true
MEMORY_STORE_PATH=data/memory

# Playwright
BROWSER_HEADLESS=true

# =========================
# 图像 RAG 配置
# =========================
IMAGE_RAG_ENABLED=true
IMAGE_CHROMA_COLLECTION_NAME=lvshe_law_images
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# =========================
# Graph RAG / Neo4j 配置
# =========================
GRAPH_RAG_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# =========================
# MinIO 对象存储配置
# =========================
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lvshe-documents
MINIO_SECURE=false

# =========================
# Unstructured.io 文档解析配置
# =========================
UNSTRUCTURED_ENABLED=true
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=

# =========================
# 合同审查输出配置
# =========================
CONTRACT_OUTPUT_DIR=output/contract_review
