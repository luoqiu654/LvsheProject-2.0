# =========================
# LvsheProject 环境变量模板
# 复制本文件为 .env 后填写真实配置
# 所有模型统一接入智谱 AI (ZhipuAI / BigModel) 平台
# =========================

APP_NAME=LvsheProject
APP_ENV=dev
APP_DEBUG=true

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ===== 智谱 AI 统一配置 =====
# 所有 6 个模型共用同一个 API Key
# 获取地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 默认语言模型（4 个文本模型可选）
# 可选值：glm-4.7-flash / glm-4.7-flashx / glm-4.6 / glm-5.2
DEFAULT_LLM_MODEL=glm-4.7-flash

# 语言模型清单（逗号分隔，用于前端模型选择）
ZHIPU_CHAT_MODELS=glm-4.7-flash,glm-4.7-flashx,glm-4.6,glm-5.2

# 文档分析视觉模型（GLM-OCR，用于图片/扫描件文字识别）
ZHIPU_VISION_MODEL=glm-ocr

# 文档批注与图片生成模型（GLM-Image）
ZHIPU_IMAGE_MODEL=glm-image

# ChromaDB
CHROMA_PERSIST_DIR=data/vector_store
CHROMA_COLLECTION_NAME=lvshe_law_docs

# 上传文件目录
UPLOAD_DIR=data/uploads

# mem0 本地模式
MEMORY_ENABLED=true
MEMORY_STORE_PATH=data/memory

# Playwright
BROWSER_HEADLESS=true

# =========================
# 图像 RAG 配置
# =========================
IMAGE_RAG_ENABLED=true
IMAGE_CHROMA_COLLECTION_NAME=lvshe_law_images
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# =========================
# Graph RAG / Neo4j 配置
# =========================
GRAPH_RAG_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# =========================
# MinIO 对象存储配置
# =========================
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lvshe-documents
MINIO_SECURE=false

# =========================
# Unstructured.io 文档解析配置
# =========================
UNSTRUCTURED_ENABLED=true
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=

# =========================
# 合同审查输出配置
# =========================
CONTRACT_OUTPUT_DIR=output/contract_review
